# additions to ~/.bashrc

# >>> persistent bash history >>>
export HISTFILE=~/bash/.bash_history
touch $HISTFILE

# >>> ROS 2 Setup >>>
# Adjust the ROS_DISTRO variable to match your installed ROS 2 distro
# Supported: humble, iron, jazzy (Ubuntu 24.04 likely uses jazzy or iron)
export ROS_DISTRO=jazzy  # change to 'iron' or 'humble' if needed

# Source ROS 2
source /opt/ros/$ROS_DISTRO/setup.bash

# activate venv
source /opt/ros_venv/bin/activate
export PYTHONPATH=/opt/ros_venv/lib/python3.12/site-packages

# Colcon workspace setup (optional)
if [ -f /workspace/install/setup.bash ]; then
    source /workspace/install/setup.bash
fi

set_ros_prompt() {
    # 1. Entferne ein eventuell bereits vorhandenes [ROS:...] Präfix aus PS1
    # Wir nutzen Bash Parameter Expansion zum Suchen und Ersetzen
    # Das Muster sucht nach dem Farbecode, "[ROS:", beliebigem Inhalt und dem Reset-Code
    local CLEAN_PS1="${PS1//\\\[\\e\[1;31m\\\]\[ROS:*\]\\\[\\e\[0m\\\] /}"

    # 2. Neues Präfix generieren, falls ID ungleich 0
    if [ -n "$ROS_DOMAIN_ID" ] && [ "$ROS_DOMAIN_ID" != "0" ]; then
        local ROS_PREFIX="\[\e[1;31m\][ROS:$ROS_DOMAIN_ID]\[\e[0m\] "
        PS1="${ROS_PREFIX}${CLEAN_PS1}"
    else
        # Falls ID 0, verwenden wir den bereinigten Prompt
        PS1="${CLEAN_PS1}"
    fi
}

# Sicherstellen, dass die Funktion bei jedem Prompt-Aufruf ausgeführt wird
PROMPT_COMMAND=set_ros_prompt

# Set DISPLAY for GUI applications (if needed)
export DISPLAY=:1